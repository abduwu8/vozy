{
  "manifest_version": 3,
  "name": "Vozy",
  "description": "Built for peak lazy mode, this voice-to-text lets you speak normally while it handles chatbots, forms, and search.",
  "version": "1.0.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>", "https://api.assemblyai.com/*"],
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "commands": {
    "toggle-dictation": {
      "suggested_key": {
        "default": "Ctrl+Shift+V",
        "mac": "Command+Shift+V"
      },
      "description": "Toggle voice dictation"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "css": ["ui.css"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "action": {
    "default_icon": {
      "16": "logo.png",
      "32": "logo.png",
      "48": "logo.png"
    },
    "default_title": "Vozy"
  }
}
